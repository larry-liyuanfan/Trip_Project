{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "itinerary_planning_v1.schema.json",
  "title": "Itinerary Planning Output v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "style_preferences",
    "hard_constraints",
    "soft_constraints",
    "required_itinerary_elements",
    "itinerary",
    "constraint_check",
    "observed_evidence",
    "unknown_fields",
    "confidence"
  ],
  "properties": {
    "style_preferences": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 120}
    },
    "hard_constraints": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 120}
    },
    "soft_constraints": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 120}
    },
    "required_itinerary_elements": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 120}
    },
    "itinerary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["day_index", "date", "summary", "activities"],
        "properties": {
          "day_index": {"type": "integer", "minimum": 1},
          "date": {"type": ["string", "null"], "minLength": 1, "maxLength": 40},
          "summary": {"type": "string", "minLength": 1, "maxLength": 120},
          "activities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "start_time",
                "end_time",
                "place_name",
                "activity",
                "transport",
                "source_evidence"
              ],
              "properties": {
                "start_time": {"type": ["string", "null"], "minLength": 1, "maxLength": 40},
                "end_time": {"type": ["string", "null"], "minLength": 1, "maxLength": 40},
                "place_name": {"type": ["string", "null"], "minLength": 1, "maxLength": 120},
                "activity": {"type": "string", "minLength": 1, "maxLength": 120},
                "transport": {"type": ["string", "null"], "minLength": 1, "maxLength": 120},
                "source_evidence": {
                  "type": "array",
                  "maxItems": 10,
                  "items": {"type": "string", "minLength": 1, "maxLength": 120}
                }
              }
            }
          }
        }
      }
    },
    "constraint_check": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["constraint", "constraint_type", "status", "evidence"],
        "properties": {
          "constraint": {"type": "string", "minLength": 1, "maxLength": 120},
          "constraint_type": {"type": "string", "enum": ["hard", "soft"]},
          "status": {"type": "string", "enum": ["satisfied", "violated", "unknown"]},
          "evidence": {"type": ["string", "null"], "minLength": 1, "maxLength": 120}
        }
      }
    },
    "observed_evidence": {
      "type": "array",
      "maxItems": 10,
      "items": {"type": "string", "minLength": 1, "maxLength": 120}
    },
    "unknown_fields": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    }
  }
}
